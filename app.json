{
  "expo": {
    "name": "Smashd",
    "slug": "smashd",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smashd",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.playsmashd.app",
      "appleTeamId": "JJ273J48DJ",
      "associatedDomains": [
        "applinks:playsmashd.com",
        "applinks:www.playsmashd.com"
      ],
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "SMASHD uses your camera to take photos of match scoreboards and Playtomic screenshots for automatic score import via OCR.",
        "NSPhotoLibraryUsageDescription": "SMASHD needs access to your photo library to import match screenshots for automatic score recognition."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.playsmashd.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "playsmashd.com",
              "pathPrefix": "/player"
            },
            {
              "scheme": "https",
              "host": "playsmashd.com",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "www.playsmashd.com",
              "pathPrefix": "/player"
            },
            {
              "scheme": "https",
              "host": "www.playsmashd.com",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#CCFF00",
          "defaultChannel": "tournament",
          "sounds": []
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "600f2f5b-a453-41b6-b316-84c03d1787e1"
      },
      "router": {}
    },
    "owner": "mikeyhurdle"
  }
}
